# NAVLYS CORE — variables d'environnement (EXEMPLE)
# Copier en `.env` (ignoré par Git) et remplir les VRAIES valeurs SUR LE SERVEUR.
# 🔴 Ne JAMAIS committer ce fichier rempli. Noms alignés sur docs/SECRETS-ET-CLES.md.

# --- Moteur (obligatoire) ---
ANTHROPIC_API_KEY=            # S4 — clé dédiée au core (pas la clé perso)
NODE_ENV=production

# --- Garde-fous / mode ---
# Mode de permission du moteur. NE PAS mettre bypassPermissions.
PERMISSION_MODE=acceptEdits
# Si true, toute action prod/argent est refusée tant que Bruno n'a pas validé.
REQUIRE_BRUNO_APPROVAL=true

# --- Mémoire persistante (recommandé) ---
REDIS_URL=                    # ex: redis://127.0.0.1:6379  (laisser vide = mémoire volatile)

# --- Branchements (remplir au fur et à mesure des chaînes) ---
GITHUB_TOKEN=                 # S6 — scope minimal (repo voulu uniquement)
VERCEL_TOKEN=                 # S7 — équipe NAVLYS
SUPABASE_URL=                 # base navlys-core
SUPABASE_SERVICE_ROLE_KEY=    # S8 — SECRET STRICT (jamais côté client)
OPENROUTER_API_KEY=           # S5 — Hermès
STRIPE_SECRET_KEY=            # S9 — MODE TEST d'abord ; argent = feu vert Bruno

# --- Audit ---
AUDIT_LOG_PATH=./logs/audit.log
