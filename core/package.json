{
  "name": "navlys-core",
  "version": "0.2.0",
  "private": true,
  "description": "Orchestrateur agentique NAVLYS (Claude Agent SDK, headless) avec garde-fous câblés et pont Kimi↔Core.",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "bridge": "node dist/bridge/runner.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "node --experimental-strip-types test/guardrails.test.mjs && node --experimental-strip-types test/bridge.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
