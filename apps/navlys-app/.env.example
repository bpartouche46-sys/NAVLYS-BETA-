# ════════════════════════════════════════════════════════════════════════════
# NAVLYS app (navlys.com) — variables d'environnement (NOMS UNIQUEMENT)
# ════════════════════════════════════════════════════════════════════════════
# RÈGLE GRAVÉE n°7 : SECRETS = ENV ONLY. Aucune VALEUR ici, jamais dans Git.
# Configurer les vraies valeurs via : vercel env add <NAME>  (Dashboard Vercel)
# Source des noms : _APP_CLIENT_DOCUMENTATION_TECHNIQUE.md §4 + _APP_CLIENT_MIDDLEWARE_AUTH.md §2
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────────────────────────
# Public (OK exposé, protégé par RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVEUR UNIQUEMENT — bypass RLS — JAMAIS dans un bundle client
SUPABASE_SERVICE_ROLE_KEY=

# ── Gate de lancement ───────────────────────────────────────────────────────
# 'false' tant que le lancement public n'est pas décidé ; 'true' à l'ouverture.
# Lancement public figé : 1er juillet 2026 00:00 (Europe/Paris). Bascule = Bruno.
NEXT_PUBLIC_LAUNCH_UNLOCKED=false

# ── URLs ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://navlys.com

# ── Chiffrement éventuel cookie ─────────────────────────────────────────────
# 32+ chars rotatable ; générer côté Bruno : openssl rand -hex 32
NAVLYS_ENCRYPTION_SECRET=

# ── Emails (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Monitoring (Sentry) ─────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Voix (ElevenLabs) — cf. live-source/api/voice.js (NAVLYS alive layer) ───
# VOICE_ID reste hors Git (quarantaine) ; n'est utilisé que côté serveur.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Déploiement Vercel (local CLI uniquement, JAMAIS commit) ────────────────
# VT=  (token Vercel deploy — variable locale, ne pas écrire ici)
