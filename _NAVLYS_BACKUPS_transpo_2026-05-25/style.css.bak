/* ============================================================
   brunopartouche.com — Style unifié
   Esthétique : luxe nocturne · pourpre/fuchsia/champagne
   Polices : Cormorant Garamond (display), Fraunces (italic),
             Lora (corps), JetBrains Mono (data)
   ============================================================ */

/* === GARANTIE FOND SOMBRE ABSOLU === */
html, body { background-color: #000000 !important; color: #e8e6f0; }
html { color-scheme: dark; }
body, main, section, article, header, footer, nav, aside, div {
  background-color: transparent;
}
body { background-color: #000000 !important; }
/* Inputs et selects forcés en sombre */
input, select, textarea, button {
  background-color: #0a0a0d;
  color: #e8e6f0;
  color-scheme: dark;
}
/* Forcer les cartes principales en noir absolu */
.stock-card, .panel-card, .status-cell, .chart-card, .sim-toolbar,
.alloc-block, .leader-card, .stat-card, .compare-table {
  background-color: #000000 !important;
}

:root {
  /* === FOND NOIR PUR PARTOUT === */
  --c-night:      #000000;     /* noir absolu */
  --c-night-2:    #000000;     /* idem - plus de dégradé */
  --c-night-3:    #000000;     /* idem */
  /* Accents pourpre / fuchsia / magenta (pour texte et bordures uniquement) */
  --c-purple-1:   #4b1a80;
  --c-purple-2:   #7c2db8;
  --c-fuchsia-1:  #c026d3;
  --c-fuchsia-2:  #e81889;
  --c-pink:       #ff5eb3;
  --c-magenta:    #d946ef;
  /* Accents chaleureux */
  --c-champagne:  #e9d3a0;
  --c-gold:       #d4a017;
  --c-pearl:      #ece4ff;     /* perle lavande, corps de texte */
  --c-pearl-soft: #b9a8e0;
  --c-mute:       #6b6680;
  /* Fonctions */
  --c-up:         #4ade80;
  --c-down:       #f87171;
  /* Surfaces — très légères, tout reste noir */
  --surf-1: rgba(192, 38, 211, 0.03);
  --surf-2: rgba(192, 38, 211, 0.06);
  --surf-3: rgba(232, 24, 137, 0.04);
  --line:   rgba(192, 38, 211, 0.28);
  --line-2: rgba(192, 38, 211, 0.12);
  /* Typographie */
  --font-display: 'Cormorant Garamond', 'Times New Roman', serif;
  --font-italic:  'Fraunces', 'Cormorant Garamond', serif;
  --font-body:    'Lora', Georgia, serif;
  --font-mono:    'JetBrains Mono', 'Fira Code', monospace;
  /* Layout */
  --maxw: 1240px;
  --pad:  clamp(1.2rem, 3vw, 2.4rem);
}

/* ====== Reset ====== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--c-night);
  color: var(--c-pearl);
  font-family: var(--font-body);
  font-size: 17px;
  line-height: 1.75;
  text-align: left;
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* Plus de dégradés atmosphériques — fond noir pur */
body::before,
body::after { content: none; display: none; }

img { max-width: 100%; display: block; }
a { color: var(--c-pink); text-decoration: none; transition: color .25s, opacity .25s; }
a:hover { color: var(--c-champagne); }

/* ====== Typo ====== */
h1, h2, h3, h4 { font-family: var(--font-display); font-weight: 500; line-height: 1.15; letter-spacing: -0.01em; }
h1 { font-size: clamp(2.4rem, 5vw, 4.2rem); }
h2 { font-size: clamp(1.8rem, 3.6vw, 2.8rem); }
h3 { font-size: clamp(1.3rem, 2.4vw, 1.7rem); }
em, .italic { font-family: var(--font-italic); font-style: italic; font-weight: 400; }
.kicker {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--c-fuchsia-1);
  display: inline-block;
  margin-bottom: 0.8rem;
}
.kicker::before { content: '— '; color: var(--c-champagne); }

/* Shimmer effet sur les titres principaux */
.shimmer {
  background: linear-gradient(
    100deg,
    var(--c-pearl) 0%,
    var(--c-pearl) 30%,
    var(--c-champagne) 50%,
    var(--c-pearl) 70%,
    var(--c-pearl) 100%
  );
  background-size: 200% auto;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: shimmer 6s linear infinite;
}
@keyframes shimmer {
  to { background-position: -200% center; }
}

/* ====== Layout ====== */
.wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--pad); }
section { padding: clamp(3rem, 7vw, 6rem) 0; position: relative; }
.section-rule {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-fuchsia-1), var(--c-purple-2), transparent);
  margin: 0 auto;
  max-width: 80%;
  opacity: 0.5;
}

/* ====== Header / Nav ====== */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
  background: rgba(0, 0, 0, 0.88);
  border-bottom: 1px solid var(--line-2);
}
.nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding: 1rem var(--pad);
  max-width: var(--maxw);
  margin: 0 auto;
}
.brand {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1.25rem;
  letter-spacing: 0.02em;
  color: var(--c-pearl);
  white-space: nowrap;
  display: flex;
  align-items: baseline;
  gap: .5rem;
}
.brand .accent { color: var(--c-champagne); font-family: var(--font-italic); font-style: italic; }
.brand:hover { color: var(--c-pearl); }

.nav-links {
  display: flex;
  gap: clamp(.5rem, 1.4vw, 1.5rem);
  list-style: none;
  flex-wrap: wrap;
  align-items: center;
}
.nav-links a {
  color: var(--c-pearl-soft);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  padding: .4rem .2rem;
  position: relative;
}
.nav-links a:hover { color: var(--c-pink); }
.nav-links a.active { color: var(--c-champagne); }
.nav-links a.active::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: -2px;
  height: 1px;
  background: linear-gradient(90deg, var(--c-fuchsia-1), var(--c-champagne));
}

.lang-toggle {
  display: inline-flex;
  border: 1px solid var(--line);
  border-radius: 100px;
  padding: 2px;
  background: var(--surf-1);
}
.lang-toggle button {
  background: transparent;
  border: none;
  color: var(--c-pearl-soft);
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.18em;
  padding: .35rem .8rem;
  border-radius: 100px;
  cursor: pointer;
  transition: all .25s;
}
.lang-toggle button.active {
  background: linear-gradient(135deg, var(--c-purple-2), var(--c-fuchsia-1));
  color: white;
}

.menu-toggle {
  display: none;
  background: transparent;
  border: 1px solid var(--line);
  color: var(--c-pearl);
  width: 38px;
  height: 38px;
  border-radius: 6px;
  font-size: 1.1rem;
  cursor: pointer;
}

/* ====== Hero ====== */
.hero {
  min-height: 92vh;
  display: flex;
  align-items: center;
  padding: clamp(4rem, 10vh, 8rem) 0 clamp(3rem, 8vh, 6rem);
  position: relative;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: center;
}
.hero h1 {
  font-size: clamp(2.6rem, 5.6vw, 5.2rem);
  margin: .8rem 0 1.6rem;
  font-weight: 400;
}
.hero h1 .swash {
  font-family: var(--font-italic);
  font-style: italic;
  font-weight: 400;
  color: var(--c-champagne);
}
.hero .subtitle {
  font-size: clamp(1rem, 1.4vw, 1.15rem);
  color: var(--c-pearl-soft);
  letter-spacing: 0.04em;
  margin-bottom: 1rem;
  font-family: var(--font-italic);
  font-style: italic;
}
.hero .location {
  font-family: var(--font-mono);
  font-size: 0.82rem;
  letter-spacing: 0.14em;
  color: var(--c-fuchsia-1);
  margin-bottom: 2.2rem;
  display: inline-block;
  padding: .4rem .9rem;
  border: 1px solid var(--line);
  border-radius: 100px;
  background: var(--surf-1);
}
.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

.hero-portrait {
  position: relative;
  aspect-ratio: 4/5;
  border-radius: 4px;
  overflow: hidden;
  box-shadow:
    0 30px 80px -20px rgba(192, 38, 211, 0.4),
    0 0 0 1px var(--line);
}
.hero-portrait::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, transparent 50%, rgba(0, 0, 0, 0.85));
  z-index: 1;
}
.hero-portrait::after {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, var(--c-fuchsia-1), transparent 30%, transparent 70%, var(--c-champagne));
  z-index: -1;
  border-radius: 4px;
  filter: blur(20px);
  opacity: 0.5;
}
.hero-portrait img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 8s ease-out;
}
.hero-portrait:hover img { transform: scale(1.06); }

.hero-quote {
  font-family: var(--font-italic);
  font-style: italic;
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  color: var(--c-champagne);
  border-left: 2px solid var(--c-fuchsia-1);
  padding-left: 1.2rem;
  max-width: 580px;
  margin-top: 2rem;
}

/* ====== Buttons ====== */
.btn {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  padding: .85rem 1.6rem;
  border-radius: 100px;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  border: 1px solid var(--line);
  background: var(--surf-1);
  color: var(--c-pearl);
  transition: all .3s;
  white-space: nowrap;
}
.btn:hover {
  background: var(--surf-2);
  border-color: var(--c-fuchsia-1);
  color: var(--c-champagne);
  transform: translateY(-2px);
}
.btn-primary {
  background: linear-gradient(135deg, var(--c-purple-2), var(--c-fuchsia-1));
  border-color: transparent;
  color: white;
  box-shadow: 0 10px 30px -10px rgba(232, 24, 137, 0.5);
}
.btn-primary:hover {
  background: linear-gradient(135deg, var(--c-fuchsia-1), var(--c-pink));
  color: white;
  box-shadow: 0 14px 40px -10px rgba(232, 24, 137, 0.7);
}

/* ====== Section title ====== */
.section-head {
  margin-bottom: clamp(2rem, 5vw, 3.5rem);
  max-width: 760px;
}
.section-head h2 {
  margin-top: .4rem;
  font-weight: 400;
}
.section-head h2 em { color: var(--c-champagne); }

/* ====== Bio (sans fin) ====== */
.bio-content { max-width: 780px; }
.bio-content p {
  margin-bottom: 1.6rem;
  font-size: 1.05rem;
}
.bio-content strong { color: var(--c-champagne); font-weight: 600; }
.bio-content em { color: var(--c-pink); font-family: var(--font-italic); font-style: italic; font-weight: 400; }

.bio-continue {
  margin-top: 3rem;
  padding: 1.6rem 2rem;
  border-left: 2px solid var(--c-fuchsia-1);
  background: rgba(232, 24, 137, 0.04);
  font-family: var(--font-italic);
  font-style: italic;
  font-size: 1.15rem;
  color: var(--c-champagne);
  border-radius: 0 6px 6px 0;
}

/* ====== Universe cards ====== */
.universe-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.4rem;
}
.u-card {
  padding: 1.8rem 1.6rem;
  background: #000000;
  border: 1px solid var(--line-2);
  border-radius: 4px;
  transition: all .35s;
  position: relative;
  overflow: hidden;
}
.u-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-fuchsia-1), transparent);
  opacity: 0;
  transition: opacity .35s;
}
.u-card:hover {
  border-color: var(--line);
  transform: translateY(-4px);
  background: rgba(192, 38, 211, 0.04);
}
.u-card:hover::before { opacity: 1; }
.u-card .icon { font-size: 1.8rem; margin-bottom: .8rem; display: block; }
.u-card h3 {
  font-family: var(--font-display);
  font-weight: 500;
  margin-bottom: .6rem;
  color: var(--c-champagne);
}
.u-card p { color: var(--c-pearl-soft); font-size: 0.96rem; }

/* ====== Ticker bourse temps réel ====== */
.ticker-wrap {
  background: #000000;
  border: 1px solid var(--line-2);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}
.ticker-strip {
  display: flex;
  gap: 0;
  overflow: hidden;
  border-bottom: 1px solid var(--line-2);
  background: var(--c-night-3);
}
.ticker-track {
  display: flex;
  gap: 0;
  animation: scroll-left 60s linear infinite;
  white-space: nowrap;
}
.ticker-track:hover { animation-play-state: paused; }
@keyframes scroll-left {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.t-item {
  display: inline-flex;
  align-items: center;
  gap: .8rem;
  padding: 1rem 1.6rem;
  border-right: 1px solid var(--line-2);
  font-family: var(--font-mono);
  font-size: 0.85rem;
}
.t-symbol { color: var(--c-champagne); font-weight: 600; letter-spacing: .04em; }
.t-price { color: var(--c-pearl); }
.t-change { font-size: 0.8rem; padding: .15rem .5rem; border-radius: 3px; }
.t-up   { color: var(--c-up);   background: rgba(74, 222, 128, 0.08); }
.t-down { color: var(--c-down); background: rgba(248, 113, 113, 0.08); }

.ticker-board {
  padding: 2rem;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1rem;
}
.t-card {
  padding: 1.2rem 1.4rem;
  background: var(--surf-1);
  border: 1px solid var(--line-2);
  border-radius: 4px;
  transition: border-color .25s, transform .25s;
}
.t-card.flash-up   { animation: flashUp .8s ease-out; }
.t-card.flash-down { animation: flashDown .8s ease-out; }
@keyframes flashUp   { 0% { background: rgba(74, 222, 128, 0.18); } 100% { background: var(--surf-1); } }
@keyframes flashDown { 0% { background: rgba(248, 113, 113, 0.18); } 100% { background: var(--surf-1); } }

.t-card .row1 { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: .3rem; }
.t-card .name { color: var(--c-pearl-soft); font-size: 0.78rem; letter-spacing: .08em; text-transform: uppercase; }
.t-card .sym  { font-family: var(--font-mono); color: var(--c-champagne); font-weight: 700; font-size: 1rem; }
.t-card .price { font-family: var(--font-mono); font-size: 1.6rem; color: var(--c-pearl); font-weight: 500; }
.t-card .row3 { display: flex; justify-content: space-between; align-items: center; margin-top: .4rem; }
.t-card .change { font-family: var(--font-mono); font-size: 0.85rem; padding: .2rem .55rem; border-radius: 3px; }
.t-card .spark  { width: 80px; height: 28px; }

.market-note {
  padding: 1rem 2rem 2rem;
  font-size: 0.86rem;
  color: var(--c-mute);
  font-style: italic;
  border-top: 1px solid var(--line-2);
  margin-top: 0;
}

/* ====== NOVA ====== */
.nova-strategy {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(1.5rem, 4vw, 3rem);
  align-items: start;
  margin-bottom: 4rem;
}
.nova-strategy h3 { color: var(--c-champagne); margin-bottom: 1rem; font-weight: 400; }
.nova-strategy strong { color: var(--c-pink); }

.nova-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}
.stat {
  padding: 1.4rem 1rem;
  background: rgba(192, 38, 211, 0.04);
  border: 1px solid var(--line);
  border-radius: 4px;
  text-align: center;
}
.stat .n {
  display: block;
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  color: var(--c-champagne);
  line-height: 1;
  margin-bottom: .4rem;
}
.stat .l {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--c-pearl-soft);
}

.tiers {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 2.5rem;
}
.tier {
  padding: 2rem 1.8rem;
  background: #000000;
  border: 1px solid var(--line-2);
  border-radius: 4px;
  position: relative;
  display: flex;
  flex-direction: column;
}
.tier.highlight {
  border-color: var(--c-fuchsia-1);
  box-shadow:
    0 20px 50px -20px rgba(232, 24, 137, 0.4),
    inset 0 1px 0 rgba(232, 24, 137, 0.2);
  transform: scale(1.02);
}
.tier.highlight::before {
  content: 'recommandé';
  position: absolute;
  top: -10px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg, var(--c-fuchsia-1), var(--c-pink));
  color: white;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: .3rem .8rem;
  border-radius: 100px;
}
.tier h3 { font-weight: 400; color: var(--c-champagne); margin-bottom: .3rem; }
.tier .tagline {
  font-family: var(--font-italic);
  font-style: italic;
  color: var(--c-pearl-soft);
  margin-bottom: 1.4rem;
  font-size: .98rem;
}
.tier .price-row {
  display: flex;
  align-items: baseline;
  gap: .4rem;
  margin-bottom: 1.4rem;
  padding-bottom: 1.4rem;
  border-bottom: 1px solid var(--line-2);
}
.tier .price {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 500;
  color: var(--c-pearl);
}
.tier .period { font-family: var(--font-mono); font-size: 0.8rem; color: var(--c-mute); }
.tier ul { list-style: none; margin-bottom: 2rem; flex: 1; }
.tier li {
  padding: .55rem 0 .55rem 1.6rem;
  position: relative;
  color: var(--c-pearl);
  font-size: 0.96rem;
  border-bottom: 1px solid var(--line-2);
}
.tier li:last-child { border: none; }
.tier li::before {
  content: '◆';
  position: absolute;
  left: 0;
  color: var(--c-fuchsia-1);
  font-size: 0.7rem;
  top: .85rem;
}
.tier .btn { width: 100%; justify-content: center; }

.nova-disclaimer {
  margin-top: 3rem;
  padding: 1.4rem 1.8rem;
  background: rgba(212, 160, 23, 0.06);
  border: 1px solid rgba(212, 160, 23, 0.18);
  border-radius: 4px;
  font-size: 0.88rem;
  color: var(--c-champagne);
  font-style: italic;
}

/* ====== Journal ====== */
.journal-entry {
  padding: 2rem 2.2rem;
  background: #000000;
  border-left: 2px solid var(--c-fuchsia-1);
  border-radius: 0 4px 4px 0;
  margin-bottom: 1.4rem;
}
.journal-entry .date {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.16em;
  color: var(--c-fuchsia-1);
  text-transform: uppercase;
  margin-bottom: .6rem;
}
.journal-entry h3 {
  font-weight: 400;
  margin-bottom: .8rem;
  color: var(--c-champagne);
}
.journal-entry p { color: var(--c-pearl); }

/* ====== Galerie ====== */
.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 0.8rem;
}
.gallery a {
  display: block;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: 4px;
  position: relative;
  border: 1px solid var(--line-2);
}
.gallery img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .8s, filter .4s;
  filter: grayscale(0.15) brightness(0.85);
}
.gallery a:hover img {
  transform: scale(1.08);
  filter: grayscale(0) brightness(1);
}

/* ====== Contact ====== */
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: start;
}
.contact-card {
  padding: 2rem;
  background: #000000;
  border: 1px solid var(--line-2);
  border-radius: 4px;
}
.contact-card .label {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--c-fuchsia-1);
  margin-bottom: .4rem;
}
.contact-card .value {
  font-family: var(--font-display);
  font-size: 1.4rem;
  color: var(--c-champagne);
  margin-bottom: 1rem;
  word-break: break-all;
}
.contact-note {
  font-style: italic;
  color: var(--c-pearl-soft);
}

/* ====== Footer ====== */
.site-footer {
  border-top: 1px solid var(--line-2);
  padding: 3rem 0 2rem;
  margin-top: 4rem;
  background: #000000;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 2rem;
  margin-bottom: 2rem;
}
.site-footer h4 {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--c-fuchsia-1);
  margin-bottom: 1rem;
  font-weight: 400;
}
.site-footer .brand-block .tagline {
  font-family: var(--font-italic);
  font-style: italic;
  color: var(--c-pearl-soft);
  margin: .6rem 0;
}
.site-footer ul { list-style: none; }
.site-footer ul li { margin-bottom: .5rem; }
.site-footer ul a { color: var(--c-pearl); font-size: 0.92rem; }
.site-footer ul a:hover { color: var(--c-pink); }
.footer-legal {
  border-top: 1px solid var(--line-2);
  padding-top: 1.4rem;
  font-size: 0.78rem;
  color: var(--c-mute);
  text-align: left;
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
}
.footer-legal .row { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }

/* ====== Responsive ====== */
@media (max-width: 920px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-portrait { max-width: 380px; margin: 0 auto; }
  .nova-strategy { grid-template-columns: 1fr; }
  .contact-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr; }
}
@media (max-width: 720px) {
  .menu-toggle { display: inline-flex; align-items: center; justify-content: center; }
  .nav-links {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: var(--c-night-2);
    flex-direction: column;
    padding: 1.5rem var(--pad);
    border-bottom: 1px solid var(--line);
    gap: 1rem;
    display: none;
  }
  .nav-links.open { display: flex; }
  .nav-links a { font-size: 0.85rem; }
  .tier.highlight { transform: none; }
}

/* ====== Selection ====== */
::selection { background: var(--c-fuchsia-1); color: white; }

/* ====== Scrollbar (webkit) ====== */
::-webkit-scrollbar { width: 10px; }
::-webkit-scrollbar-track { background: var(--c-night); }
::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--c-purple-2), var(--c-fuchsia-1));
  border-radius: 100px;
  border: 2px solid var(--c-night);
}

/* ============================================================
   📦 ENCADRÉS HARMONISÉS — pass de polissage v13
   Règles globales pour tous les types de boxes du site
   ============================================================ */

/* Toutes les boxes héritent du fond noir absolu et d'une transition douce */
.panel-card, .hero-card, .result-hero, .verdict-box, .success-card,
.security-badge, .badge-cert, .ideal-for, .quiz-result, .arch-block,
.explainer, .feature-row, .stat-card, .summary-card, .order-summary,
.payment-info, .offre-card, .offre-mini, .formula-card, .broker-card,
.tile, .stock-card, .leader-card, .compare-table, .chart-box,
.chart-card, .alloc-block, .api-card, .bot-card, .stat-cell,
.event-row, .feature-section {
  background-color: #000000 !important;
  transition: border-color 0.3s ease, transform 0.25s ease, box-shadow 0.3s ease;
}

/* Effet hover unifié sur les cartes interactives */
.tile:hover, .offre-mini:hover, .formula-card:hover, .broker-card:hover,
.preset-btn:hover, .formula-card:hover {
  border-color: var(--c-fuchsia-1) !important;
}

/* Effet de focus net pour accessibilité */
*:focus-visible {
  outline: 2px solid var(--c-champagne);
  outline-offset: 2px;
}

/* Encadrés "highlight" / accentués */
.panel-card.popular, .offre-card.popular, .offre-mini.selected,
.formula-card.active, .broker-card.selected, .tile.featured {
  border-color: var(--c-champagne) !important;
  background: linear-gradient(135deg, rgba(0,0,0,1), rgba(233,211,160,0.04)) !important;
  box-shadow: 0 8px 30px -12px rgba(233, 211, 160, 0.3);
}

/* Badges (certifications, statuts) */
.badge-cert, .security-badge, .badge {
  background-color: rgba(74, 222, 128, 0.05) !important;
}

/* Animations d'apparition pour les flash announces */
@keyframes flashIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
.result-hero, .success-card, .quiz-result {
  animation: flashIn 0.5s ease;
}

/* Lien partenaire — style discret */
.partner-link {
  color: var(--c-fuchsia-1);
  text-decoration: none;
  border-bottom: 1px dotted var(--c-fuchsia-1);
  transition: all 0.2s;
}
.partner-link:hover {
  color: var(--c-champagne);
  border-bottom-color: var(--c-champagne);
}

/* Skip-link pour accessibilité (caché jusqu'à focus) */
.skip-link {
  position: absolute;
  top: -100px;
  left: 0;
  background: var(--c-champagne);
  color: #000;
  padding: .8rem 1.2rem;
  font-family: var(--font-mono);
  font-size: .8rem;
  text-decoration: none;
  z-index: 9999;
}
.skip-link:focus { top: 0; }

/* Améliorer la lisibilité des kickers répétés */
.kicker {
  font-feature-settings: 'tnum';
}

/* ============================================================
   Fix mobile : éviter le débordement horizontal
   ============================================================ */
html, body { overflow-x: hidden; max-width: 100vw; }
img, video, iframe { max-width: 100%; height: auto; }
table { display: block; overflow-x: auto; }

/* =========================================================
   RESPIRATION ICE BLUE — éclairage LED ambiant (toutes pages)
   Ajouté pour brunopartouche.com — charte ICE BLUE #7DD3FC
   ========================================================= */
:root{ --ice-blue:#7DD3FC; }

body::after{
  content:""; position:fixed; left:0; right:0; top:0; bottom:0;
  pointer-events:none; z-index:1;
  background:
    radial-gradient(72% 28% at 50% 0%,   rgba(125,211,252,0.12), transparent 70%),
    radial-gradient(72% 26% at 50% 100%, rgba(125,211,252,0.10), transparent 70%);
  mix-blend-mode:screen;
  animation: iceBreath 7s ease-in-out infinite;
}
@keyframes iceBreath{ 0%,100%{ opacity:.4 } 50%{ opacity:1 } }

/* Cartes qui respirent en ice blue */
.breathe-card{ animation: iceCardBreath 6s ease-in-out infinite; }
@keyframes iceCardBreath{
  0%,100%{ border-color: rgba(125,211,252,0.18); box-shadow: 0 0 0 rgba(125,211,252,0); }
  50%{     border-color: rgba(125,211,252,0.55); box-shadow: 0 0 38px -10px rgba(125,211,252,0.45); }
}

/* Filets de section : pulsation LED ice blue */
.section-rule{ position:relative; }
.section-rule::after{
  content:""; position:absolute; left:50%; top:50%; height:2px; transform:translate(-50%,-50%);
  background:linear-gradient(90deg, transparent, var(--ice-blue), transparent);
  animation: iceRulePulse 5s ease-in-out infinite;
}
@keyframes iceRulePulse{ 0%,100%{ opacity:.25; width:90px } 50%{ opacity:.9; width:170px } }

/* Liseré ice blue qui respire sur le bloc invitation NAVLYS */
.navlys-invite{ animation: iceCardBreath 6.5s ease-in-out infinite; }

@media (prefers-reduced-motion: reduce){
  body::after, .breathe-card, .section-rule::after, .navlys-invite{ animation:none; }
}
