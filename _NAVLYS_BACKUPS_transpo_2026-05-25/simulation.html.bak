3,0.0,0.000231,0.00033,0.000528,0.0,-0.000132,0.000165,0.000132,0.000363,0.0,0.000264,-3.3e-05,6.6e-05,0.000396,0.0,0.000132,-3.3e-05,-0.00023,0.00056,0.0,0.0,0.000373,0.000231,0.000396,0.0,0.000198,9.9e-05,-0.000164,0.000561,0.0,0.00023,0.00033,0.000296,0.000165,0.0,0.000198,0.000165,-3.3e-05,0.000165,0.0,0.000165,-0.00023,-3.2e-05,0.000362,0.0,0.000264,6.6e-05,0.000429,0.000165,0.0,9.9e-05,3.3e-05,3.3e-05,0.000165,0.0,0.000132,0.000132,0.000198,0.000395,0.0,0.000263,9.9e-05,0.0,0.0,0.000198,0.000231,0.000132,0.000231,0.0,-9.9e-05,0.000329,0.000264,0.000133,0.0,3.3e-05,0.000132,0.000197,0.000321,0.0,3.3e-05,0.000462,0.0,0.0,0.00023,3.3e-05,0.0,0.0,9.9e-05,0.000165,3.3e-05,6.6e-05,0.0,0.000165,9.9e-05,-3.3e-05,0.00033,0.0,0.000329,-6.5e-05,0.000428,0.0,0.000131,0.000198,9.9e-05,0.000329,0.0,0.000198,0.000165,0.000132,0.000297,0.0,0.000165,-0.000197,0.000264,0.000527,0.0,6.6e-05,9.9e-05,0.000264,0.0,-6.6e-05,0.000165,0.000198,6.6e-05,0.0,6.6e-05,-6.6e-05,9.9e-05,0.000133,0.0,-0.000198,0.0,-0.000428,0.000231,0.0,0.00033,-3.3e-05,-6.6e-05,-0.000296,0.0,3.4e-05,6.6e-05,-0.000296,0.000165,0.0,0.00033,0.000248,0.000463,0.0,0.000297,0.000198,3.3e-05,0.000199,0.0,6.6e-05,0.000198,-0.0,0.000495,0.0,-6.6e-05,9.9e-05,0.000165,0.000429,0.0,0.000198,-3.3e-05,6.6e-05,0.000437,0.0,0.000298,0.000429,3.3e-05,0.000364]};

const PROFILS = {
  "Zen":       { coffre: 0.97, tp: 0.020, tesa_default: 1.00, sweep_default: 0.00, color: "#86EFAC" },
  "Précision": { coffre: 0.90, tp: 0.080, tesa_default: 0.50, sweep_default: 0.10, color: "#7DD3FC" },
  "Boost":     { coffre: 0.70, tp: 0.070, tesa_default: 0.30, sweep_default: 0.10, color: "#E8D4A2" },
};
const PROFIL_DETAILS = {
  "Zen": { class: "zen", emoji: "🛡️", title: "NAVLYS Zen · sommeil tranquille", desc: "97% coffre · 3% poche dynamique · TP +2% · tésaurisation 100% · sweep 0%" },
  "Précision": { class: "precision", emoji: "🎯", title: "NAVLYS Précision · l'horloger suisse", desc: "90% coffre · 10% poche dynamique · TP +8% · tésaurisation 50% · sweep mensuel 10%" },
  "Boost": { class: "boost", emoji: "🚀", title: "NAVLYS BOOST · croissance maximale", desc: "70% coffre · 30% poche dynamique · TP +7% · tésaurisation 30% · sweep mensuel 10%" },
};
const TICKERS = ["SOL", "NVDA", "AVGO"];

// =================== MOTEUR DE SIMULATION ===================
function simuler(profilName, capitalInit, dcaMensuel, tesaTp, sweepPct, nYears) {
  const params = PROFILS[profilName];
  const ratioCoffre = params.coffre;
  const tp = params.tp;

  // Sélection des données dans la fenêtre nYears
  const allDates = NOVA_DATA.dates;
  const totalDays = allDates.length;
  // 5 ans = ~252 jours bourse × 5 mais nos données crypto sont 365j/an → 1256 jours pour 5 ans
  const daysNeeded = Math.round(totalDays * (nYears / 5));
  const start = Math.max(0, totalDays - daysNeeded);

  // Prix initiaux pour calcul des quantités
  const prices = {
    SOL: NOVA_DATA.prices.SOL.slice(start),
    NVDA: NOVA_DATA.prices.NVDA.slice(start),
    AVGO: NOVA_DATA.prices.AVGO.slice(start),
  };
  const retCoffreArr = NOVA_DATA.ret_coffre.slice(start);
  const dates = NOVA_DATA.dates.slice(start);
  const n = dates.length;

  // Initialisation
  let coffre = capitalInit * ratioCoffre;
  const capDynTotal = capitalInit * (1 - ratioCoffre);
  const capParActif = capDynTotal / TICKERS.length;
  const capRef = { SOL: capParActif, NVDA: capParActif, AVGO: capParActif };
  const quantites = {
    SOL: capParActif / prices.SOL[0],
    NVDA: capParActif / prices.NVDA[0],
    AVGO: capParActif / prices.AVGO[0],
  };

  let totalApporte = capitalInit;
  let tpCount = 0, tpGainsCoffre = 0, tpGainsReinvestis = 0;
  let sweepCount = 0, sweepTotal = 0;
  let dcaCount = 0, dcaTotal = 0;

  // Historique pour graphiques
  const histCoffre = new Array(n);
  const histDyn = new Array(n);
  const histTotal = new Array(n);
  const histApporte = new Array(n);

  let lastMonth = new Date(dates[0]).getMonth();
  let lastYear = new Date(dates[0]).getFullYear();

  for (let i = 0; i < n; i++) {
    const d = new Date(dates[i]);

    // 1. Coffre : rendement journalier
    if (i > 0) coffre *= (1 + retCoffreArr[i]);

    // 2. DCA mensuel + Sweep mensuel
    const isNewMonth = (d.getMonth() !== lastMonth) || (d.getFullYear() !== lastYear);
    if (isNewMonth && i > 0 && dcaMensuel > 0) {
      coffre += dcaMensuel * ratioCoffre;
      const dcaDynTotal = dcaMensuel * (1 - ratioCoffre);
      const dcaParActif = dcaDynTotal / TICKERS.length;
      for (const t of TICKERS) {
        quantites[t] += dcaParActif / prices[t][i];
        capRef[t] += dcaParActif;
      }
      totalApporte += dcaMensuel;
      dcaCount++;
      dcaTotal += dcaMensuel;
    }
    if (isNewMonth && i > 0 && sweepPct > 0) {
      let surplusTotal = 0;
      for (const t of TICKERS) {
        const val = quantites[t] * prices[t][i];
        surplusTotal += Math.max(0, val - capRef[t]);
      }
      if (surplusTotal > 0) {
        const sweepAmount = surplusTotal * sweepPct;
        for (const t of TICKERS) {
          const val = quantites[t] * prices[t][i];
          const surplusT = Math.max(0, val - capRef[t]);
          if (surplusT > 0) {
            const part = (surplusT / surplusTotal) * sweepAmount;
            quantites[t] -= part / prices[t][i];
            coffre += part;
          }
        }
        sweepCount++;
        sweepTotal += sweepAmount;
      }
    }
    if (isNewMonth && i > 0) {
      lastMonth = d.getMonth();
      lastYear = d.getFullYear();
    }

    // 3. Take-profits
    for (const t of TICKERS) {
      const val = quantites[t] * prices[t][i];
      if (val >= capRef[t] * (1 + tp)) {
        const gain = val - capRef[t];
        const auCoffre = gain * tesaTp;
        const auReinvest = gain * (1 - tesaTp);
        coffre += auCoffre;
        const nouveauCap = capRef[t] + auReinvest;
        quantites[t] = nouveauCap / prices[t][i];
        capRef[t] = nouveauCap;
        tpCount++;
        tpGainsCoffre += auCoffre;
        tpGainsReinvestis += auReinvest;
      }
    }

    // 4. Valorisation
    const valDyn = quantites.SOL * prices.SOL[i] + quantites.NVDA * prices.NVDA[i] + quantites.AVGO * prices.AVGO[i];
    histCoffre[i] = coffre;
    histDyn[i] = valDyn;
    histTotal[i] = coffre + valDyn;
    histApporte[i] = totalApporte;
  }

  // Métriques
  const valeurFinale = histTotal[n-1];
  const plusValue = valeurFinale - totalApporte;
  // Drawdown
  let hwm = histTotal[0], ddMax = 0;
  for (let i = 0; i < n; i++) {
    if (histTotal[i] > hwm) hwm = histTotal[i];
    const dd = (histTotal[i] - hwm) / hwm;
    if (dd < ddMax) ddMax = dd;
  }

  return {
    dates, histCoffre, histDyn, histTotal, histApporte,
    apportTotal: totalApporte, valeurFinale, plusValue,
    perfPct: (plusValue / totalApporte) * 100,
    ddMaxPct: ddMax * 100,
    tpCount, sweepCount, dcaCount,
    tpGainsCoffre, tpGainsReinvestis, sweepTotal, dcaTotal,
  };
}

// =================== UI ===================
const $ = (id) => document.getElementById(id);
const fmtEur = (v) => v.toLocaleString("fr-FR", { maximumFractionDigits: 0 }) + " €";
const fmtPct = (v) => (v >= 0 ? "+" : "") + v.toFixed(2) + "%";

let state = {
  profil: "Précision",
  capital: 500,
  dca: 100,
  tesa: 50,
  sweep: 10,
  years: 5,
  view: "total",
};

let chart = null;

function updateSliderFill(input) {
  const min = parseFloat(input.min), max = parseFloat(input.max), val = parseFloat(input.value);
  const pct = ((val - min) / (max - min)) * 100;
  input.style.setProperty("--p", pct + "%");
}

function applyProfilDefaults(profilName) {
  const p = PROFILS[profilName];
  state.tesa = Math.round(p.tesa_default * 100);
  state.sweep = Math.round(p.sweep_default * 100);
  $("tesa").value = state.tesa;
  $("sweep").value = state.sweep;
  $("valTesa").textContent = state.tesa;
  $("valSweep").textContent = state.sweep;
  updateSliderFill($("tesa"));
  updateSliderFill($("sweep"));
  const det = PROFIL_DETAILS[profilName];
  const elDet = $("profilDetail");
  elDet.className = "profil-detail " + det.class;
  elDet.innerHTML = "<strong>" + det.emoji + " " + det.title + "</strong><br>" + det.desc;
}

function runSimulation() {
  const res = simuler(
    state.profil,
    state.capital,
    state.dca,
    state.tesa / 100,
    state.sweep / 100,
    state.years
  );

  // Stats
  $("rApport").textContent = fmtEur(res.apportTotal);
  $("rApportSub").textContent = res.dcaCount > 0 ?
    (fmtEur(state.capital) + " + " + res.dcaCount + " × " + fmtEur(state.dca)) :
    "Capital initial seul";
  $("rValeur").textContent = fmtEur(res.valeurFinale);
  $("rValeurSub").textContent = "après " + state.years + " an" + (state.years > 1 ? "s" : "");
  $("rPV").textContent = fmtEur(res.plusValue);
  $("rPV").className = "stat-value " + (res.plusValue >= 0 ? "pos" : "neg");
  $("rPVPct").textContent = fmtPct(res.perfPct) + " sur apports";
  $("rPVPct").className = "stat-sub " + (res.plusValue >= 0 ? "pos" : "neg");
  $("rDD").textContent = res.ddMaxPct.toFixed(2) + "%";
  $("rDDSub").textContent = res.tpCount + " TP · " + res.sweepCount + " sweeps · " + res.dcaCount + " DCA";

  // Chart
  renderChart(res);
}

function renderChart(res) {
  const ctx = $("chart").getContext("2d");
  if (chart) { chart.destroy(); }
  const labels = res.dates.map((d, i) => i % 30 === 0 ? d.substring(0, 7) : "");
  const profilColor = PROFILS[state.profil].color;

  let datasets;
  if (state.view === "total") {
    datasets = [{
      label: "Valeur totale du portefeuille",
      data: res.histTotal,
      borderColor: profilColor,
      backgroundColor: profilColor + "22",
      borderWidth: 2,
      fill: true,
      pointRadius: 0,
      tension: 0.15,
    }, {
      label: "Total apporté (capital + DCA)",
      data: res.histApporte,
      borderColor: "#94A3B8",
      backgroundColor: "transparent",
      borderWidth: 1.5,
      borderDash: [5, 4],
      fill: false,
      pointRadius: 0,
    }];
  } else if (state.view === "split") {
    datasets = [{
      label: "Coffre (sécurisé)",
      data: res.histCoffre,
      borderColor: "#7DD3FC",
      backgroundColor: "#7DD3FC55",
      borderWidth: 1.5,
      fill: "origin",
      stack: "main",
      pointRadius: 0,
      tension: 0.1,
    }, {
      label: "Poche dynamique (SOL+NVDA+AVGO)",
      data: res.histDyn,
      borderColor: "#E8D4A2",
      backgroundColor: "#E8D4A255",
      borderWidth: 1.5,
      fill: "-1",
      stack: "main",
      pointRadius: 0,
      tension: 0.1,
    }];
  } else { // apport
    const plusValueSerie = res.histTotal.map((v, i) => v - res.histApporte[i]);
    datasets = [{
      label: "Total apporté (capital + DCA)",
      data: res.histApporte,
      borderColor: "#94A3B8",
      backgroundColor: "#94A3B833",
      borderWidth: 2,
      fill: true,
      pointRadius: 0,
    }, {
      label: "Plus-value (gain pur)",
      data: plusValueSerie,
      borderColor: profilColor,
      backgroundColor: profilColor + "55",
      borderWidth: 2,
      fill: "-1",
      pointRadius: 0,
    }];
  }

  chart = new Chart(ctx, {
    type: "line",
    data: { labels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 500, easing: "easeOutQuart" },
      interaction: { mode: "index", intersect: false },
      plugins: {
        legend: {
          position: "top",
          labels: { color: "#CBD5E1", font: { size: 12, family: "Lora" } }
        },
        tooltip: {
          backgroundColor: "rgba(15, 15, 18, 0.95)",
          borderColor: "#7DD3FC",
          borderWidth: 1,
          titleColor: "#7DD3FC",
          bodyColor: "#F0F9FF",
          callbacks: {
            label: function(ctx) { return ctx.dataset.label + " : " + fmtEur(ctx.parsed.y); }
          }
        }
      },
      scales: {
        x: {
          grid: { color: "rgba(125,211,252,0.06)" },
          ticks: { color: "#64748B", maxRotation: 0, autoSkip: true, maxTicksLimit: 10 }
        },
        y: {
          grid: { color: "rgba(125,211,252,0.06)" },
          ticks: { color: "#94A3B8", callback: v => fmtEur(v) }
        }
      }
    }
  });
}

// =================== EVENTS ===================
document.querySelectorAll(".profil-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".profil-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    state.profil = btn.dataset.profil;
    applyProfilDefaults(state.profil);
    runSimulation();
  });
});

document.querySelectorAll(".tab").forEach(t => {
  t.addEventListener("click", () => {
    document.querySelectorAll(".tab").forEach(x => x.classList.remove("active"));
    t.classList.add("active");
    state.view = t.dataset.view;
    runSimulation();
  });
});

document.querySelectorAll(".preset").forEach(p => {
  p.addEventListener("click", () => {
    const target = p.dataset.target;
    const value = parseInt(p.dataset.value);
    $(target).value = value;
    state[target] = value;
    $("val" + target.charAt(0).toUpperCase() + target.slice(1)).textContent = value.toLocaleString("fr-FR");
    updateSliderFill($(target));
    runSimulation();
  });
});

["capital", "dca", "tesa", "sweep", "years"].forEach(id => {
  const el = $(id);
  el.addEventListener("input", () => {
    state[id] = parseFloat(el.value);
    const label = $("val" + id.charAt(0).toUpperCase() + id.slice(1));
    if (label) label.textContent = state[id].toLocaleString("fr-FR");
    updateSliderFill(el);
    runSimulation();
  });
  updateSliderFill(el);
});

// Init
applyProfilDefaults("Précision");
runSimulation();
</script>

</body>
</html>