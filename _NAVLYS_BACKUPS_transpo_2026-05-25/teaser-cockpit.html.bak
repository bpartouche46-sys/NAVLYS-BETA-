};
let LANG="fr";
function S(id,v){const e=document.getElementById(id);if(e)e.textContent=v;}
function setLang(l){LANG=l;document.documentElement.lang=l;
  document.getElementById("L-fr").classList.toggle("on",l==="fr");
  document.getElementById("L-en").classList.toggle("on",l==="en");
  const t=TXT[l];
  S("t-tag",t.tag);S("t-cast",t.cast);S("t-prec",t.prec);S("t-notify",t.notify);S("t-try",t.try);S("t-scroll",t.scroll);
  S("s-d",t.sd);S("s-h",t.sh);S("s-m",t.sm);S("s-s",t.ss);
  S("t-ec",t.ec);S("t-hc",t.hc);S("t-lc",t.lc);S("t-ed",t.ed);S("t-hd",t.hd);S("t-ld",t.ld);
  S("c1h",t.c1h);S("c1p",t.c1p);S("c1g",t.c1g);S("c2h",t.c2h);S("c2p",t.c2p);S("c2g",t.c2g);
  S("c3h",t.c3h);S("c3p",t.c3p);S("c3g",t.c3g);S("c4h",t.c4h);S("c4p",t.c4p);S("c4g",t.c4g);
  S("t-foot",t.foot);
}
setLang("fr");
</script>
