# ── NAVLYS CORE worker — variables d'environnement ──
# NE JAMAIS committer le vrai .env (il est dans .gitignore).

# Supabase (projet navlys-core)
SUPABASE_URL=https://hhrlgyvtqluxpywjiwkd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__REMPLACER__cle_service_role__jamais_committer__

# LLM via OpenRouter (mets une SPEND LIMIT sur la clé)
OPENROUTER_API_KEY=__REMPLACER__
NAVLYS_DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# Réglages du worker
NAVLYS_POLL_SECONDS=30
NAVLYS_MAX_TOKENS=1500
NAVLYS_MEMORY_LIMIT=8

# Alertes "à valider" (optionnel — human-in-the-loop)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Site navlys.com (fonctions Vercel — à régler dans Vercel, pas ici) ──
# Voix NAVLYS (ElevenLabs) — endpoint /api/voice
ELEVENLABS_API_KEY=__REMPLACER__cote_vercel__
ELEVENLABS_VOICE_ID=__REMPLACER__cote_vercel__
# Clone animé (HeyGen) — endpoint /api/clone. ⚠️ Génération = vrai débit (Bible §6).
HEYGEN_API_KEY=__REMPLACER__cote_vercel__
HEYGEN_AVATAR_ID=__REMPLACER__avatar_entraine_sur_le_visage_de_Bruno__
HEYGEN_VOICE_ID=__OPTIONNEL__sinon_audio_url__
