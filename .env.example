# ── NAVLYS CORE worker — variables d'environnement ──
# NE JAMAIS committer le vrai .env (il est dans .gitignore).

# Supabase (projet navlys-core)
SUPABASE_URL=https://hhrlgyvtqluxpywjiwkd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__REMPLACER__cle_service_role__jamais_committer__

# ── Cerveau LLM ─────────────────────────────────────────────────────────
# 1) Clé ANTHROPIC DIRECTE (payante) — RECOMMANDÉE, c'est le canal indépendant.
#    Obtenir : console.anthropic.com -> Billing (ajouter un moyen de paiement)
#    -> API keys -> Create key. Mets une SPEND LIMIT (Usage limits) par sécurité.
#    Lecture tolérante : ANTHROPIC_API_KEY | CLAUDE_API_KEY | CLAUDE_CODE_API_KEY.
ANTHROPIC_API_KEY=__REMPLACER__sk-ant-...__jamais_committer__

# 2) OpenRouter — désormais OPTIONNEL : filet de secours anti-coupure.
#    Si Anthropic tombe, le CORE bascule seul dessus (mets une spend limit aussi).
OPENROUTER_API_KEY=

# Préférence de fournisseur : auto (défaut) | anthropic | openrouter
#   auto = Anthropic direct d'abord, OpenRouter en repli.
NAVLYS_LLM_PROVIDER=auto

# Modèles (IDs canoniques). NAVLYS_DEFAULT_MODEL sert de défaut ;
# NAVLYS_ANTHROPIC_MODEL force l'ID Anthropic direct si tu veux le fixer.
NAVLYS_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
NAVLYS_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Réglages du worker ──────────────────────────────────────────────────
NAVLYS_POLL_SECONDS=30
NAVLYS_MAX_TOKENS=1500
NAVLYS_MEMORY_LIMIT=8

# ── Autopilote (le CORE se dirige seul, sans la voix de Bruno) ───────────
# 1 = actif (défaut). Le CORE établit lui-même la feuille de route.
NAVLYS_AUTOPILOT=1
# Fréquence de planification (heures) et nombre max de missions par passe.
NAVLYS_AUTOPILOT_HOURS=6
NAVLYS_AUTOPILOT_MAX=6

# Alertes "à valider" (optionnel — human-in-the-loop)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
