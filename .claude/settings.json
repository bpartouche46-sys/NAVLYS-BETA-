{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "mcp__Supabase",
      "mcp__Vercel",
      "mcp__github",
      "mcp__Zapier",
      "mcp__Netlify",
      "mcp__Gmail",
      "mcp__Google_Drive",
      "mcp__Google_Calendar",
      "mcp__Google_Sheets",
      "mcp__Stripe",
      "mcp__PayPal",
      "mcp__Adobe_for_creativity",
      "mcp__Canva",
      "mcp__Figma",
      "mcp__HyperFrames_by_HeyGen",
      "mcp__Notion",
      "mcp__Semrush",
      "mcp__Spotify",
      "mcp__Descrybe_Legal_Engine",
      "mcp__Malwarebytes",
      "mcp__Microsoft_Learn",
      "mcp__Supermetrics_Marketing_Analytics",
      "mcp__Synthesize_Bio",
      "mcp__Docusign",
      "mcp__FMP",
      "mcp__Kiwi_com",
      "mcp__PDF_Viewer",
      "mcp__Dropbox"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/tools/hook-verif.mjs\""
          }
        ]
      }
    ]
  }
}
